# Your home subway station(s) — GTFS parent stop id(s), comma-separated for multiple.
# Each must exist in server/src/data/stations.json. Example: 127,635
STATION=127,635

# kiosk | phone | auto
DISPLAY_MODE=kiosk

# Compact view: denser layout, fewer arrivals, and only severe alerts (good for
# small / e-ink screens). This is the default for all clients; any device can
# override per-URL with ?compact=1 or ?compact=0. true|false (also 1/0, yes/no)
COMPACT=false

# Weather location (Open-Meteo, no API key needed)
WEATHER_LAT=40.7580
WEATHER_LON=-73.9855

# Poll intervals / staleness (seconds)
FEED_REFRESH_SEC=30
WEATHER_REFRESH_SEC=600
# Alerts feed poll interval (seconds) — alerts change slowly
ALERTS_REFRESH_SEC=120
STALE_THRESHOLD_SEC=90

# Unused for subway; reserved for future bus (SIRI) support
MTA_API_KEY=

# HTTP port
PORT=8080
